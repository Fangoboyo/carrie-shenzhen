{
    "name": "Luckfox Pico Dev",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "luckfox-dev",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "llvm-vs-code-extensions.vscode-clangd",
                "KylinIdeTeam.kylin-clangd"
            ]
        },
        "antigravity": {
            "agentContext": "container",
            "capabilities": ["shell", "filesystem", "network"]
        }
    },
    "workspaceFolder": "/workspaces/rv1103-dev"
}